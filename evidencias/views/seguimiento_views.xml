<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_seguimiento_cliente" model="ir.actions.act_window">
        <field name="name">Seguimiento Clientes</field>
        <field name="res_model">seguimiento.cliente</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pendiente': 1}</field>
    </record>

    <menuitem id="menu_seguimiento_cliente_root" name="Clientes" parent="sales_team.menu_sales" sequence="5"/>

    <menuitem id="menu_seguimiento_cliente" name="Seguimiento" parent="menu_seguimiento_cliente_root" action="action_seguimiento_cliente"/>

    <record id="view_seguimiento_cliente_search" model="ir.ui.view">
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <search string="Buscar Seguimientos">
                <field name="nombre"/>
                <field name="cliente_id"/>
                <filter string="Pendientes" name="pendiente" domain="[('estado', '=', 'pendiente')]"/>
            </search>
        </field>
    </record>

    <record id="view_seguimiento_cliente_list" model="ir.ui.view">
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <list string="Seguimientos">
                <field name="nombre"/>
                <field name="cliente_id"/>
                <field name="fecha"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <record id="view_seguimiento_cliente_form" model="ir.ui.view">
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <form string="Seguimiento Cliente">
                <header>
                    <button name="action_marcar_realizado" string="Marcar Realizado" type="object" class="oe_highlight" invisible="estado == 'realizado'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="pendiente,realizado"/>
                </header>
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="cliente_id"/>
                        <field name="fecha"/>
                    </group>
                    <group>
                        <field name="estado"/>
                        <field name="notas"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>