<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_seguimiento" model="ir.actions.act_window">
        <field name="name">Seguimiento Clientes</field>
        <field name="res_model">seguimiento.cliente</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_seguimiento" name="Seguimiento Clientes" action="action_seguimiento"/>

    <record id="view_seguimiento_list" model="ir.ui.view">
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <list string="Seguimientos">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_seguimiento_form" model="ir.ui.view">
        <field name="model">seguimiento.cliente</field>
        <field name="arch" type="xml">
            <form string="Seguimiento">
                <header>
                    <button name="action_done" string="Marcar Realizado" type="object" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="date"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>